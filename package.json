{
  "name": "jira-tracker-web",
  "version": "1.0.0",
  "description": "Jira Project Tracker Web App",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"node server/index.js\" \"vite --config client/vite.config.js\"",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/index.js",
    "install:client": "echo 'Client deps included in root'"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^5.1.6"
  }
}
